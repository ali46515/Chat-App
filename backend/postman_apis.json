{
    "info": {
        "_postman_id": "c348e6b5-7536-447a-9e71-9e0c9d79c4cd",
        "name": "WhatsApp Clone API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "Postman collection for the WhatsApp-clone backend (Node/Express/MongoDB/Socket.io). All requests use the {{baseUrl}} variable. After a successful login the JWT token is stored in {{authToken}} and reused automatically."
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000",
            "type": "string",
            "description": "Base URL of the API (change to your production URL, e.g. https://api.my‑app.com)"
        },
        {
            "key": "authToken",
            "value": "",
            "type": "string",
            "description": "JWT token – automatically set after Login request"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "register"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Alice\",\n  \"phone\": \"1111111111\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123\"\n}"
                        }
                    },
                    "response": []
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"phoneOrEmail\": \"1111111111\",\n  \"password\": \"Password123\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Grab the JWT from the response and store it as an environment variable",
                                    "var json = pm.response.json();",
                                    "if (json.token) {",
                                    "    pm.environment.set(\"authToken\", json.token);",
                                    "    console.log(\"✅ authToken saved\");",
                                    "} else {",
                                    "    console.warn(\"⚠️ No token in response\");",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "response": []
                }
            ]
        },
        {
            "name": "Users",
            "item": [
                {
                    "name": "Get My Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/users/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "me"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Update My Profile",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/users/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "me"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Alice Updated\",\n  \"status\": \"Hey! I am using the new app\"\n}"
                        }
                    },
                    "response": []
                },
                {
                    "name": "Search Users",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/users/search?term=alice",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "search"
                            ],
                            "query": [
                                {
                                    "key": "term",
                                    "value": "alice"
                                }
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Chats",
            "item": [
                {
                    "name": "Create / Get One‑on‑One Chat (accessChat)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/chats",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "chats"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"participantId\": \"{{otherUserId}}\"\n}"
                        }
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Save the chat ID for later use",
                                    "var json = pm.response.json();",
                                    "if (json._id) {",
                                    "    pm.environment.set(\"chatId\", json._id);",
                                    "    console.log(\"✅ chatId saved: \" + json._id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ]
                },
                {
                    "name": "Create Group Chat",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/chats/group",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "chats",
                                "group"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Friends Group\",\n  \"participantIds\": [\"{{otherUserId}}\", \"{{thirdUserId}}\"]\n}"
                        }
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var json = pm.response.json();",
                                    "if (json._id) {",
                                    "    pm.environment.set(\"groupChatId\", json._id);",
                                    "    console.log(\"✅ groupChatId saved: \" + json._id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ]
                },
                {
                    "name": "Get My Chats",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/chats",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "chats"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Send Text Message",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/chats/{{chatId}}/message",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "chats",
                                "{{chatId}}",
                                "message"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"content\": \"Hello from Postman!\"\n}"
                        }
                    },
                    "response": []
                },
                {
                    "name": "Send Message with File (use uploaded file URL)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/chats/{{chatId}}/message",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "chats",
                                "{{chatId}}",
                                "message"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"content\": \"Check this file!\",\n  \"file\": {\n    \"url\": \"{{uploadedFileUrl}}\",\n    \"mimeType\": \"image/jpeg\",\n    \"originalName\": \"my-photo.jpg\"\n  }\n}"
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Last 50 Messages",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/chats/{{chatId}}/messages?limit=50",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "chats",
                                "{{chatId}}",
                                "messages"
                            ],
                            "query": [
                                {
                                    "key": "limit",
                                    "value": "50"
                                }
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Files",
            "item": [
                {
                    "name": "Upload File (multipart/form‑data)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/files/upload",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "files",
                                "upload"
                            ]
                        },
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "file",
                                    "type": "file",
                                    "src": ""
                                }
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Save the public URL for later use in a message",
                                    "var json = pm.response.json();",
                                    "if (json.url) {",
                                    "    pm.environment.set(\"uploadedFileUrl\", json.url);",
                                    "    console.log(\"✅ uploadedFileUrl saved: \" + json.url);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "response": []
                },
                {
                    "name": "Delete Uploaded File",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{authToken}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/files/{{fileId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "files",
                                "{{fileId}}"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ]
}